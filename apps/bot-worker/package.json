{
  "name": "bot-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wrangler build",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "register:commands": "ts-node scripts/register-commands.ts",
    "test": "vitest run",
    "test:watch": "vitest",
