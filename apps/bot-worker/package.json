    "@botmedic/rules": "file:../../packages/rules",
    "@noble/ed25519": "^1.7.1",
    "dotenv": "^10.0.0",
    "undici": "^6.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "0.34.6",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.0",
    "vitest": "0.34.6",
    "wrangler": "^3.10.0"
  }
}
